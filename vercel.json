{
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "nodeVersion": "22.x",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "font-src 'self' vercel.com *.vercel.com vercel.live instant-preview-site.vercel.app *.gstatic.com *.public.blob.vercel-storage.com k2mkucxia43oc7fa.public.blob.vercel-storage.com;"
        }
      ]
    }
  ]
}
